{
    "name": "vscode-powerquery-scripts",
    "description": "Scripts for vscode-powerquery repository",
    "author": "Microsoft Corporation",
    "license": "MIT",
    "homepage": "https://github.com/microsoft/vscode-powerquery#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/microsoft/vscode-powerquery.git",
        "directory": "server"
    },
    "issues": {
        "url": "https://github.com/microsoft/vscode-powerquery/issues"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc -watch",
        "test": "mocha --reporter mocha-multi-reporters --reporter-options configFile=src/test/mochaConfig.json -r ts-node/register src/test/**/*.ts",
        "link:start": "npm link && npm uninstall @microsoft/powerquery-parser @microsoft/powerquery-language-services && npm install && npm link @microsoft/powerquery-parser @microsoft/powerquery-language-services",
        "link:stop": "npm unlink @microsoft/powerquery-parser @microsoft/powerquery-language-services && npm install && npm install @microsoft/powerquery-parser@latest @microsoft/powerquery-language-services@latest --save-exact",
        "lint": "eslint src --ext ts",
        "webpack-prod": "webpack --mode production",
        "webpack-dev": "webpack --watch --mode development"
    },
    "engines": {
        "node": ">= 22"
    },
    "dependencies": {
        "@microsoft/powerquery-language-services": "^1.0.0",
        "@microsoft/powerquery-parser": "^0.19.0",
        "vscode-languageserver-textdocument": "^1.0.4"
    }
}
